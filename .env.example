# The absolute path to your Obsidian vault where Daemon.md will operate.
# Example: "~/Library/Mobile Documents/com~apple~CloudDocs/Daemon_Vault"
# Make sure to wrap paths containing spaces in quotes!
VAULT_PATH=""

# Your Google Gemini API Key
GEMINI_API_KEY=""

# Model configurations (Optional, defaults are provided below)
# Use the fastest available model for the daemon routing
GEMINI_MODEL_DAEMON="gemini-3.1-flash-lite-preview"
# Use a highly capable reasoning model for the weekly linter
GEMINI_MODEL_LINTER="gemini-3.1-pro-preview"
